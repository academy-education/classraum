# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Site Configuration  
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Recurring Payments Cron Job
# Generate a secure random string for this (e.g., openssl rand -base64 32)
CRON_SECRET_KEY=your-super-secret-cron-key-here

# PortOne Platform API (for settlements and payouts)
PORTONE_API_SECRET=your_portone_api_secret_here
PORTONE_STORE_ID=your_portone_store_id_here

# Alert Configuration (optional)
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_RECIPIENTS=admin@classraum.com
ALERT_EMAIL_FROM=alerts@classraum.com
SLACK_WEBHOOK_URL=

# ───────────────────────────────────────────────────────────────────────
# Sentry Error Monitoring
# Get these from https://sentry.io after creating your project.
# Leaving them blank disables Sentry — the app still runs normally.
# See docs/SENTRY_SETUP.md for full setup instructions.
# ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=